# Videó pull: DSM2 (naszareti) → nasznagy (BP)
# Telepítés: csak a DSM2-n (/volume1/homes/sitkeitamas/scripts/)
SCRIPT_DIR="/volume1/homes/sitkeitamas/scripts"
FOLDERS_CONF="${FOLDERS_CONF:-${SCRIPT_DIR}/sync_folders.conf}"
LOG_FILE="${SCRIPT_DIR}/video_pull.log"
PID_DIR="/tmp"

REMOTE_USER="sitkeitamas"
# Közvetlen IP VPN-en (split-DNS: nasznagy.synology.me → 192.168.5.9)
REMOTE_HOST="192.168.5.9"
REMOTE_PORT="22"
SSH_OPTS="-o ConnectTimeout=15 -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

# 0 = nincs limit; pl. 100000 ≈ 100 MB/s (Telekom 1G fel Edericsen)
RSYNC_BWLIMIT="0"

# Poll trigger (ha használod sync_video_pull_trigger.sh)
POLL_INTERVAL_SEC="1800"
