# Közös videó-szinkron beállítások (forrás: sitkeitamas scripts a nasznagyon)
SCRIPT_DIR="/volume1/homes/sitkeitamas/scripts"
FOLDERS_CONF="${SCRIPT_DIR}/sync_folders.conf"
LOG_FILE="${SCRIPT_DIR}/video_sync.log"
PID_DIR="/tmp"

REMOTE_USER="sitkeitamas"
REMOTE_HOST="dsm2.sitkeitamas.hu"
REMOTE_PORT="22"
SSH_OPTS="-o ConnectTimeout=15 -o BatchMode=yes"

# 0 = nincs limit (rsync --bwlimit=0); pl. 6000 ≈ 6 MB/s
RSYNC_BWLIMIT="0"

# Videó vezérlés áthelyezve DSM2-re (kétirányú bidir) — nasznagy trigger NE fusson
VIDEO_SYNC_DISABLED=1

# inotify hiányában ennyi másodpercenként poll (fallback)
POLL_INTERVAL_SEC="120"

# Feladatütemezőből felülírható extra mappák (szóközzel elválasztva):
#   export SYNC_VIDEO_EXTRA="/volume1/video/foo|/volume1/video/foo"
# SYNC_VIDEO_EXTRA=""
