# Videó kétirányú sync — vezérlés a DSM2-n (naszareti)
# Telepítés: /volume1/homes/sitkeitamas/scripts/ a DSM2-n
SCRIPT_DIR="/volume1/homes/sitkeitamas/scripts"
FOLDERS_CONF="${FOLDERS_CONF:-${SCRIPT_DIR}/sync_folders.conf}"
LOG_FILE="${SCRIPT_DIR}/video_bidir.log"
PID_DIR="/tmp"

BP_USER="sitkeitamas"
BP_HOST="192.168.5.9"
BP_PORT="22"
SSH_OPTS="-o ConnectTimeout=15 -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

RSYNC_BWLIMIT="0"
POLL_INTERVAL_SEC="120"
# find/ssh ellenőrzés max másodperc (ne ragadjon be TB scan-nel)
MTIME_CHECK_TIMEOUT="45"

# Kényszerítés: mindkét irány (sync_video_bidir_now.sh)
SYNC_BIDIR_FORCE="${SYNC_BIDIR_FORCE:-0}"
