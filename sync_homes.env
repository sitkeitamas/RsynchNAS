# Homes → naszika (DSM3) geo-redundancia
SCRIPT_DIR="/volume1/homes/sitkeitamas/scripts"
FOLDERS_CONF="${FOLDERS_CONF:-${SCRIPT_DIR}/sync_homes_folders.conf}"
LOG_FILE="${SCRIPT_DIR}/homes_sync.log"
STAMP_FILE="/tmp/sync_homes_laststamp"
PENDING_FILE="/tmp/sync_homes_pending"
PID_DIR="/tmp"

REMOTE_USER="sitkeitamas"
REMOTE_HOST="192.168.9.29"
REMOTE_PORT="22"
SSH_OPTS="-o ConnectTimeout=15 -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

# ~2 MB/s — videó (6000) alatt, ne foglalja el a sávot
RSYNC_BWLIMIT="2000"

# 30 percenként változás-ellenőrzés
POLL_INTERVAL_SEC="1800"

# Tényleges másolás csak ebben az óra-ablakban (helyi idő, 24h)
SYNC_HOUR_START="1"
SYNC_HOUR_END="6"

# Azonnali sync kényszerítés: SYNC_HOMES_FORCE=1 bash sync_homes_to_dsm3.sh
# HOMES_TRANSPORT: rsync | tar | auto (auto = rsync, ha DSM3-on be van kapcsolva az rsync szolgáltatás)
HOMES_TRANSPORT="auto"
