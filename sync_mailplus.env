# MailPlus → dsm2 (naszareti) passzív standby másolat
# Forrás: nasznagy /volume1/@MailPlus-Server
# Cél:    naszareti /volume1/NetBackup/mailplus-server/  (failover: vissza @MailPlus-Server)

SCRIPT_DIR="/volume1/homes/sitkeitamas/scripts"
LOG_FILE="${SCRIPT_DIR}/mailplus_sync.log"

REMOTE_USER="sitkeitamas"
REMOTE_HOST="192.168.9.19"
REMOTE_PORT="22"
REMOTE_DEST="/volume1/NetBackup/mailplus-server"

SOURCE="/volume1/@MailPlus-Server"

SSH_OPTS="-o ConnectTimeout=15 -o BatchMode=yes -o StrictHostKeyChecking=accept-new"

# ~1 MB/s — kis adat, ne zavarja a videó syncet
RSYNC_BWLIMIT="1000"

# Éjszakai ablak (helyi idő) — homes sync után
SYNC_HOUR_START="2"
SYNC_HOUR_END="5"

# Kényszerítés: SYNC_MAILPLUS_FORCE=1 ./sync_mailplus_to_dsm2.sh
# Dry run:    SYNC_MAILPLUS_DRY_RUN=1 ./sync_mailplus_to_dsm2.sh
